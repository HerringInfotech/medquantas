{
  "name": "costing-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "./node_modules/@angular/cli/bin/ng",
    "start": "node --max-old-space-size=8192 index.js",
    "start:prod": "SET NODE_ENV=production && node --max-old-space-size=8192 index.js",
    "start:dev": "SET NODE_ENV=developer && node --max-old-space-size=8192 index.js",
    "serve": "nodemon --max-old-space-size=8192 index.js",
    "ang": "ng serve --port 6100",
    "ang:dev": "ng serve --port 6100 --configuration developer",
    "ang:prod": "ng serve --port 6100 --configuration production",
    "build-master-app": "ng build master-app --configuration production --deploy-url",
    "build-master-app:dev": "ng build master-app --configuration developer --deploy-url"
  },
  "private": true,
